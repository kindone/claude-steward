{
  "name": "claude-steward",
  "private": true,
  "type": "module",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "start": "npm run start --workspace=server",
    "up": "node scripts/up.js prod",
    "up:dev": "node scripts/up.js dev",
    "down": "node scripts/tier.js down all --force",
    "down:prod": "node scripts/tier.js down prod",
    "down:dev": "node scripts/tier.js down dev",
    "down:safe": "node scripts/tier.js down safe",
    "restart": "node scripts/tier.js restart all --force",
    "restart:prod": "node scripts/tier.js restart prod",
    "restart:dev": "node scripts/tier.js restart dev",
    "restart:safe": "node scripts/tier.js restart safe",
    "logs": "pm2 logs",
    "logs:prod": "node scripts/tier.js logs prod",
    "logs:dev": "node scripts/tier.js logs dev",
    "logs:safe": "node scripts/tier.js logs safe",
    "test": "npm test --workspace=server && npm test --workspace=client",
    "test:e2e": "npm run test:e2e --workspace=server && playwright test",
    "test:all": "npm test && npm run test:e2e",
    "status": "node scripts/status.js",
    "stock-chart": "npx tsx scripts/stock-chart.ts",
    "compare-chart": "npx tsx scripts/compare-chart.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.1.0",
    "typescript": "^6.0.2"
  }
}
