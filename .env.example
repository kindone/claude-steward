# Optional: secret for "Sign in with API key" in the UI. Compose maps this to the
# container as API_KEY when you use docker compose.
API_KEY=change-me-before-use
PORT=3001
SAFE_PORT=3003
# DATABASE_PATH=./steward.db   # optional override; defaults to server/steward.db
NODE_ENV=development
CLAUDE_PATH=/Users/ubuntu/.local/bin/claude
APP_DOMAIN=steward.example.com  # required for HTTPS deployments; used as WebAuthn rpID — must exactly match the hostname you access the app from
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
# Anthropic key for claude api calls (optional)
ANTHROPIC_API_KEY=
# Long-lived OAuth token generated via `claude setup-token`.
STEWARD_TEST_OAUTH_TOKEN=
GEMINI_API_KEY=
OPENAI_API_KEY=
# opencode (Docker): default when a session has no model — provider/model, e.g. google/gemma-4-31b-it
# OPENCODE_DEFAULT_MODEL=google/gemma-4-31b-it