# Build artefacts (rebuilt inside Docker)
server/dist/
server/public/
client/dist/
node_modules/
server/node_modules/
client/node_modules/
apps/*/node_modules/
apps/*/dist/

# Database — never bake production DB into the image
server/steward.db
*.db

# Runtime / OS
.env
.env.*
*.log
.DS_Store

# Dev tooling
# Note: .git/ is intentionally NOT excluded — runtime-evolve copies the full
# /app from the builder so the in-container steward has access to git history
# (log, diff, blame, commit). Adds ~18 MB to the build context, negligible.
# The minimal runtime stage doesn't copy .git/, so its image is unaffected.
.claude/
coverage/
